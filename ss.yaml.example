# Space Station Configuration
# Copy this file to ss.yaml and update with your settings

repo: "owner/repo-name"
spacestation_dir: "~/space-station"
editor: "cursor"
default_agent: "claude --enable-auto-mode --effort low"
planets:
  - mercury
  - venus
  - earth
  - mars
base_port: 8000
port_step: 1000
