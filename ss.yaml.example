# Space Station Configuration
# Copy this file to ss.yaml and update with your settings

# GitHub repository (owner/repo format)
REPO: "owner/repo-name"

# Directory where planets will be created (default: ~/{project}/space-station)
SPACESTATION_DIR: "~/myproject/space-station"

# Editor to open planets in (optional, defaults to cursor)
EDITOR: "cursor"

# List of planet names
PLANETS:
  - mercury
  - venus
  - earth
  - mars

# Starting port for the first planet
BASE_PORT: 8000

# Port offset between each planet
PORT_STEP: 1000
