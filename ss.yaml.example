# Space Station Configuration
# Copy this file to ss.yaml and update with your settings

repo: "owner/repo-name"
spacestation_dir: "~/myproject/space-station"
editor: "cursor"
default_agent: "claude --allow-dangerously-skip-permissions --permission-mode bypassPermissions --effort low"
planets:
  - mercury
  - venus
  - earth
  - mars
base_port: 8000
port_step: 1000
